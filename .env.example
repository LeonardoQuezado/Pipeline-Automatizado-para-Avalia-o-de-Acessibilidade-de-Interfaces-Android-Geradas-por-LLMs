GEMINI_API_KEY=your_key_here
GROQ_API_KEY=your_key_here
DEEPSEEK_API_KEY=your_key_here
XAI_API_KEY=your_key_here
OPENAI_API_KEY=your_key_here
ANTHROPIC_API_KEY=your_key_here

# Android device for ATF instrumented tests (optional)
# 1. Enable USB debugging on your phone and connect via USB
# 2. Run from Windows CMD: adb connect <phone_wifi_ip>:5555  (accept dialog on phone)
# 3. Set the two vars below:
EMULATOR_HOST=host.docker.internal
# ADB keys dir — lets Docker use the same trusted keys as Windows.
# Use forward slashes. Example: C:/Users/leoqu/.android
ADB_KEYS_DIR=
